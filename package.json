{
  "name": "prompt-local-vault",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "description": "Local-first prompt management tool for AI-heavy teams.",
  "productName": "Prompt Vault",
  "author": "guochen",
  "license": "MIT",
  "scripts": {
    "dev": "node server/dev.js",
    "dev:web": "vite --host 127.0.0.1",
    "dev:api": "node --experimental-sqlite server/index.js",
    "open:web": "node scripts/open-web.js",
    "desktop": "npm run build && electron .",
    "server": "node --experimental-sqlite server/index.js",
    "build": "tsc -b && vite build",
    "make:win": "npm run build && electron-forge make --platform=win32",
    "start": "node --experimental-sqlite server/index.js --serve-static",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "fastify": "^5.6.2",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.7",
    "jsdom": "^27.3.0",
    "playwright": "^1.60.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.15"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "Prompt Vault",
        "executableName": "Prompt Vault",
        "asar": true
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "PromptVault",
            "setupExe": "PromptVaultSetup.exe",
            "noMsi": true
          }
        }
      ]
    }
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
